{
  "mcpServers": {
    "agent_handler": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://agent-proxy.perplexity.ai/merge_mcp",
        "--header",
        "Authorization: Bearer ${PERPLEXITY_MCP_TOKEN}"
      ],
      "env": {
        "AUTH_TOKEN": "${PERPLEXITY_MCP_TOKEN}"
      }
    }
  }
}
