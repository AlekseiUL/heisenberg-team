# ============================================
# Heisenberg Team - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Replace all {{PLACEHOLDER}} with actual data

# === API KEYS ===
ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key  # uncomment only if workers/embeddings require it
GOOGLE_API_KEY=your-google-key

# --- Embedding (for vector memory search) ---
# OpenAI recommended. Skip if you don't need semantic search.
# OPENAI_API_KEY=your-openai-key  # (same as above if using OpenAI as LLM)

# --- Models (set by setup wizard) ---
# === LLM Models ===
# Level 1: Strategic (user-facing, decision-making)
MAIN_MODEL=anthropic/claude-sonnet-4-5-20250929
COORDINATOR_MODEL=anthropic/claude-sonnet-4-5-20250929

# Level 2: Technical (coding, PDF generation, complex tasks)
# TECH_MODEL=anthropic/claude-sonnet-4-6

# Level 3: Workers (marketing, finance, security, research, goals)
# WORKER_MODEL=anthropic/claude-haiku-4-5

# Level 4: Background (cron jobs, health checks, monitoring)
# CRON_MODEL=google/gemini-2.5-flash

# Embeddings
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# === Heisenberg (Boss) — Claude Sonnet 4.5 ===
HEISENBERG_PROVIDER=anthropic
HEISENBERG_MODEL=claude-sonnet-4-5-20250929
HEISENBERG_MAX_TOKENS=4096
HEISENBERG_API_KEY=${ANTHROPIC_API_KEY}

# === Saul (Coordinator) — Claude Sonnet 4.5 ===
SAUL_PROVIDER=anthropic
SAUL_MODEL=claude-sonnet-4-5-20250929
SAUL_MAX_TOKENS=4096

# --- Telegram (optional) ---
# TELEGRAM_BOT_TOKEN=your-bot-token
# OWNER_TELEGRAM_ID=your-telegram-id

# --- Personal Data ---
# Used in agent configs for personalization
OWNER_NAME=YourName
OWNER_SURNAME=YourSurname
OWNER_USERNAME=your-github-username

# --- Paths ---
# WORKSPACE_PATH=~/workspace/
# PROJECTS_PATH=~/projects/

# --- GitHub (optional) ---
# GITHUB_ORG=your-github-org
# GITHUB_TOKEN=your-github-token

# --- MCP (optional) ---
# PERPLEXITY_MCP_TOKEN=your-perplexity-mcp-token

# --- Webhooks (optional) ---
# WEBHOOK_TOKEN=your_webhook_token_here

# --- Notifications (optional) ---
# GROUP_CHAT_ID=your-group-chat-id
# NOTIFY_CHANNEL_ID=your-notify-channel-id
